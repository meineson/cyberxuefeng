{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "cyberxuefeng",
	"main": "src/worker.js",
	"compatibility_date": "2026-04-13",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {}
  },
	"assets": {
		"directory": "./public",
		"binding": "ASSETS"
	},
  "kv_namespaces": [
    {
      "binding": "APP_KV",
      "id": "0153701c09b640e38e749c5518174202",
      "preview_id": "ff061acb6d2f404399b820041d4b2488",
      "remote": false
    }
  ],
	"vars": {
		"SKILL_SLUG": "zhangxuefeng-perspective",
		"SEARCH_PROVIDER": "tavily",
		"BASE_URL": "https://coding.dashscope.aliyuncs.com/v1",
		"OPENAI_MODEL": "glm-5",
		"MAX_MESSAGE_LENGTH": "300",
		"RATE_LIMIT_MAX": "5",
		"RATE_LIMIT_WINDOW_MS": "60000"
	}
}

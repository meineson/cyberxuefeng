{
  "name": "cyberxuefeng",
  "version": "1.0.0",
  "description": "AI Agent for single skill using LangChain",
  "type": "module",
  "scripts": {
    "build:css": "node scripts/build-tailwind-css.mjs",
    "build": "npm run build:css",
    "dev": "npm run build && wrangler dev --local",
    "deploy": "npm run build && wrangler deploy",
    "kv:sync-skill": "node scripts/sync-skill-to-kv.mjs",
    "kv:sync-skill:local": "node scripts/sync-skill-to-kv.mjs --local",
    "kv:sync-skill:local:prod": "node scripts/sync-skill-to-kv.mjs --local --preview=false",
    "test:worker": "node tests/worker.test.js",
    "zhangxuefeng": "npm run dev"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.0.2",
    "@langchain/openai": "^1.2.11",
    "@tavily/core": "^0.5.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "langchain": "^1.2.18",
    "undici": "^7.20.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/node": "^4.2.2",
    "tailwindcss": "^4.2.1",
    "wrangler": "^4.11.1"
  }
}

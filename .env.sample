# === WebSearch 配置 ===
# 搜索提供方：gemini / tavily（默认 gemini）
SEARCH_PROVIDER=gemini

# Gemini 配置（SEARCH_PROVIDER=gemini 时使用）
GEMINI_API_KEY=
# 可选：手工指定搜索模型（不填则自动按内置顺序回退）
# GEMINI_MODEL=gemini-2.5-flash-lite

# Tavily 配置（SEARCH_PROVIDER=tavily 时使用）
TAVILY_API_KEY=

BASE_URL=https://coding.dashscope.aliyuncs.com/v1
PORT=80
# OPENAI_MODEL=MiniMax-M2.5
# OPENAI_MODEL=kimi-k2.5
# OPENAI_MODEL=glm-4.7
OPENAI_MODEL=glm-5
API_KEY=

# 认证密码（前端简单认证）
AUTH_PASSWORD=sbxf2026

# 技能路径配置（支持多技能切换）
SKILL_PATH=./skills/zhangxuefeng-perspective
